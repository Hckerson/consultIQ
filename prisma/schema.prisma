// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  REJECT
  HOLD
  PURSUE
  PRIORITY_PURSUE
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum Urgency {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum Duration {
  SHORT
  LONG
  VERY_LONG
}

enum SkillSet {
  PROBLEM_SOLVING @map("Problem Solving")
  COMMUNICATION
  TEAMWORK
  LEADERSHIP
  ADAPTABILITY
  TIME_MANAGEMENT @map("Time Management")
  OTHER
}

enum Role {
  ADMIN
  CONSULTANT
  SUPER_ADMIN
  CLIENT
}

enum Specialization {
  TECHNOLOGY
  BUSINESS
  FINANCE
  MARKETING
  SALES
  HUMAN_RESOURCES @map("Human Resources")
  OTHER
}

model Consultant {
  id          String @id @unique @default(cuid())
  userId      String @unique
  successRate Int

  user          User                  @relation(fields: [userId], references: [id])
  skillSet      ConsultantSkillSet[]
  qualification ConsultantExperience?
  bookings      ConsultantBooking[]
}

model ConsultantBooking {
  id           String   @id @unique @default(cuid())
  consultantId String
  status       String
  startDate    DateTime
  endDate      DateTime

  consultant Consultant @relation(fields: [consultantId], references: [id])
}

model ConsultantExperience {
  id           String @id @unique @default(cuid())
  consultantId String @unique

  consultant          Consultant   @relation(fields: [consultantId], references: [id])
  specialization      Experience?  @relation("Specialization")
  otherQualifications Experience[] @relation("OtherQualifications")
}

model ConsultantSkillSet {
  id           String @id @unique @default(cuid())
  consultantId String

  name       SkillSet
  level      SkillLevel
  consultant Consultant @relation(fields: [consultantId], references: [id])
}

model Contract {
  id          String @id @unique @default(cuid())
  companyName String @unique
}

model Experience {
  years              Int
  id                 String   @id @unique @default(cuid())
  title              String
  specializationOfId String   @unique
  otherOfId          String?
  niches             String[]

  specializationOf ConsultantExperience  @relation("Specialization", fields: [specializationOfId], references: [id])
  otherOf          ConsultantExperience? @relation("OtherQualifications", fields: [otherOfId], references: [id])
}

model Lead {
  score       Int
  blockers    Json
  clientInfo  Json
  termination Json
  id          String  @id @unique @default(cuid())
  processed   Boolean @default(false)
  discarded   Boolean @default(false)

  status LeadStatus?
}

model User {
  id           String   @id @unique @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String   @unique
  address      String
  city         String?
  state        String?
  zip          String?
  country      String?
  consultantId String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  consultant Consultant?

  @@index([id, email])
}
